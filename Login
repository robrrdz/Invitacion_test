<%@ Page Language="C#" AutoEventWireup="true" CodeBehind="Login.aspx.cs" Inherits="ScoreCards.Login" %>

<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title>ScoreCards | Login</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            min-height: 100vh;
            overflow: hidden;
            background: linear-gradient(135deg, #0f172a 0%, #111827 45%, #1e293b 100%);
            position: relative;
        }

        .background-glow {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: rgba(59, 130, 246, 0.18);
            filter: blur(120px);
            z-index: 0;
        }

        .glow-1 {
            top: -120px;
            left: -120px;
        }

        .glow-2 {
            bottom: -180px;
            right: -100px;
            background: rgba(139, 92, 246, 0.18);
        }

        .login-wrapper {
            position: relative;
            z-index: 2;
            min-height: 100vh;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(255,255,255,0.10);
            border-radius: 28px;
            padding: 45px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.35);
        }

        .brand-icon {
            width: 80px;
            height: 80px;
            border-radius: 22px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
            margin-bottom: 25px;
            box-shadow: 0 8px 30px rgba(59, 130, 246, 0.45);
        }

        .brand-icon i {
            font-size: 34px;
            color: white;
        }

        .title {
            color: white;
            font-weight: 700;
            font-size: 2rem;
        }

        .subtitle {
            color: rgba(255,255,255,0.70);
            font-size: 0.95rem;
            margin-bottom: 35px;
        }

        .form-control {
            height: 55px;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.08);
            background-color: rgba(255,255,255,0.08);
            color: white;
            padding-left: 48px;
        }

        .form-control:focus {
            background-color: rgba(255,255,255,0.12);
            color: white;
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.25rem rgba(59,130,246,.25);
        }

        .form-control::placeholder {
            color: rgba(255,255,255,0.45);
        }

        .input-group-text {
            position: absolute;
            z-index: 5;
            height: 55px;
            width: 50px;
            border: none;
            background: transparent;
            color: rgba(255,255,255,0.70);
        }

        .input-wrapper {
            position: relative;
            margin-bottom: 22px;
        }

        .btn-login {
            height: 55px;
            border-radius: 16px;
            border: none;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            color: white;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(59,130,246,0.35);
        }

        .extra-links a {
            color: rgba(255,255,255,0.75);
            text-decoration: none;
            font-size: 0.9rem;
        }

        .extra-links a:hover {
            color: white;
        }

        .score-badge {
            background: rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 12px 18px;
            color: white;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            margin-top: 20px;
            font-size: 0.9rem;
        }

        .score-badge i {
            color: #22c55e;
        }

        @media(max-width: 768px) {
            .login-card {
                padding: 30px 25px;
            }
        }
    </style>
</head>
<body>

    <div class="background-glow glow-1"></div>
    <div class="background-glow glow-2"></div>

    <form id="form1" runat="server">

        <div class="container login-wrapper d-flex justify-content-center align-items-center">

            <div class="col-lg-4 col-md-6 col-11">

                <div class="login-card">

                    <div class="text-center">

                        <div class="brand-icon">
                            <i class="fa-solid fa-chart-line"></i>
                        </div>

                        <h1 class="title">ScoreCards</h1>

                        <p class="subtitle">
                            Accede al panel de indicadores y rendimiento operativo
                        </p>

                    </div>

                    <!-- Usuario -->
                    <div class="input-wrapper">
                        <span class="input-group-text">
                            <i class="fa-solid fa-user"></i>
                        </span>

                        <asp:TextBox 
                            ID="txtUsuario" 
                            runat="server" 
                            CssClass="form-control"
                            placeholder="Usuario">
                        </asp:TextBox>
                    </div>

                    <!-- Password -->
                    <div class="input-wrapper">
                        <span class="input-group-text">
                            <i class="fa-solid fa-lock"></i>
                        </span>

                        <asp:TextBox 
                            ID="txtPassword" 
                            runat="server" 
                            TextMode="Password"
                            CssClass="form-control"
                            placeholder="Contraseña">
                        </asp:TextBox>
                    </div>

                    <!-- Recordar -->
                    <div class="d-flex justify-content-between align-items-center mb-4">

                        <div class="form-check">
                            <asp:CheckBox ID="chkRecordar" runat="server" CssClass="form-check-input" />
                            <label class="form-check-label text-white-50">
                                Recordarme
                            </label>
                        </div>

                        <div class="extra-links">
                            <a href="#">¿Olvidaste tu contraseña?</a>
                        </div>

                    </div>

                    <!-- Botón -->
                    <div class="d-grid">
                        <asp:Button 
                            ID="btnLogin" 
                            runat="server" 
                            Text="Iniciar Sesión"
                            CssClass="btn btn-login" />
                    </div>

                    <!-- Mensaje -->
                    <div class="text-center mt-4">
                        <asp:Label 
                            ID="lblMensaje" 
                            runat="server" 
                            ForeColor="#f87171">
                        </asp:Label>
                    </div>

                    <!-- Badge -->
                    <div class="text-center">
                        <div class="score-badge">
                            <i class="fa-solid fa-shield-halved"></i>
                            Plataforma segura de métricas y desempeño
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </form>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
